[Unit]
Description=Unity Video Producer
After=network.target

[Service]
Type=simple
User=master_srkkhpugvw
WorkingDirectory=/var/www/unity-video-producer/backend
EnvironmentFile=/var/www/unity-video-producer/.env
ExecStart=/usr/bin/python3 -m uvicorn main:app --host 0.0.0.0 --port 8000 --workers 2
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
